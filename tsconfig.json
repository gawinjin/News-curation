{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["astro/client"],
    "allowJs": true,
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["src", "scripts", "astro.config.mjs"],
  "exclude": ["dist", "node_modules"]
}
