---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{items.length >= 2 && (
  <aside class="hidden lg:block sticky top-24 self-start text-sm" aria-label="Table of contents">
    <h2 class="text-xs uppercase tracking-wide text-[color:var(--muted)] mb-3">On this page</h2>
    <ul class="space-y-1.5">
      {items.map((h) => (
        <li class={h.depth === 3 ? 'pl-3' : ''}>
          <a
            href={`#${h.slug}`}
            data-toc-link
            data-target={h.slug}
            class="block py-0.5 text-[color:var(--muted)] hover:text-[color:var(--accent)] transition-colors border-l-2 border-transparent pl-3 -ml-3"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<script is:inline>
  (function () {
    const links = document.querySelectorAll('[data-toc-link]');
    if (!links.length) return;
    const headingEls = Array.from(links)
      .map((l) => document.getElementById(l.getAttribute('data-target') || ''))
      .filter(Boolean);
    if (!headingEls.length) return;

    function onScroll() {
      const y = window.scrollY + 140;
      let activeId = headingEls[0].id;
      for (const el of headingEls) {
        if (el.offsetTop <= y) activeId = el.id;
      }
      links.forEach((l) => {
        const isActive = l.getAttribute('data-target') === activeId;
        l.style.color = isActive ? 'var(--accent)' : '';
        l.style.borderLeftColor = isActive ? 'var(--accent)' : 'transparent';
      });
    }
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>
