---
// Toggles the #reading-progress bar visibility + width on the current page.
---

<script is:inline>
  (function () {
    const bar = document.getElementById('reading-progress');
    if (!bar) return;

    function update() {
      const el = document.querySelector('[data-article-body]') || document.body;
      const rect = el.getBoundingClientRect();
      const start = window.scrollY + rect.top;
      const end = start + rect.height - window.innerHeight;
      const y = window.scrollY;
      const pct = Math.min(1, Math.max(0, (y - start) / Math.max(1, end - start)));
      bar.style.width = pct * 100 + '%';
      bar.style.opacity = y > 200 ? '1' : '0';
    }
    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    document.addEventListener('astro:after-swap', update);
  })();
</script>
