---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('articles', ({ data }) => !data.draft);
  const tags = new Set<string>();
  for (const e of entries) for (const t of e.data.tags) tags.add(t);
  return Array.from(tags).map((t) => ({ params: { tag: t } }));
}

const tag = Astro.params.tag as string;
const articles = (await getCollection('articles', ({ data }) => !data.draft && data.tags.includes(tag))).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title={`#${tag}`} description={`Articles tagged ${tag}`} pathname={Astro.url.pathname}>
  <section class="max-w-page mx-auto px-5 sm:px-8 pt-14 pb-6">
    <p class="text-xs uppercase tracking-[0.18em] text-[color:var(--accent)] font-medium">Tag</p>
    <h1 class="mt-2 font-serif text-4xl md:text-5xl font-bold tracking-tight">#{tag}</h1>
    <p class="mt-3 text-[color:var(--muted)]">{articles.length} article{articles.length === 1 ? '' : 's'}</p>
  </section>

  <section class="max-w-page mx-auto px-5 sm:px-8 mt-6">
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {articles.map((a) => (
        <ArticleCard
          href={`/articles/${a.slug}`}
          title={a.data.title}
          summary={a.data.summary}
          date={a.data.date}
          category={a.data.category}
          tags={a.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
