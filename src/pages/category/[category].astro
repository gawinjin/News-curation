---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, CATEGORY_ORDER } from '../../lib/categories';
import type { CategorySlug } from '../../lib/categories';

export async function getStaticPaths() {
  return CATEGORY_ORDER.map((c) => ({ params: { category: c } }));
}

const category = Astro.params.category as CategorySlug;
const meta = CATEGORIES[category];
const articles = (await getCollection('articles', ({ data }) => !data.draft && data.category === category)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title={meta.label} description={meta.blurb} pathname={Astro.url.pathname}>
  <section class="max-w-page mx-auto px-5 sm:px-8 pt-14 pb-6">
    <p class="text-xs uppercase tracking-[0.18em] text-[color:var(--accent)] font-medium">Category</p>
    <h1 class="mt-2 font-serif text-4xl md:text-5xl font-bold tracking-tight">{meta.label}</h1>
    <p class="mt-3 text-lg text-[color:var(--muted)] max-w-2xl">{meta.blurb}</p>
  </section>

  <section class="max-w-page mx-auto px-5 sm:px-8 mt-6">
    {articles.length === 0 ? (
      <p class="text-[color:var(--muted)]">Nothing here yet — check back soon.</p>
    ) : (
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((a) => (
          <ArticleCard
            href={`/articles/${a.slug}`}
            title={a.data.title}
            summary={a.data.summary}
            date={a.data.date}
            category={a.data.category}
            tags={a.data.tags}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
