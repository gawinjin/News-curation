---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../lib/categories';

const all = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const byYear = new Map<number, typeof all>();
for (const a of all) {
  const y = a.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, [] as any);
  (byYear.get(y) as any).push(a);
}
const years = Array.from(byYear.keys()).sort((a, b) => b - a);
---

<BaseLayout title="Archive" description="Every article on Signal, by year." pathname="/archive">
  <section class="max-w-page mx-auto px-5 sm:px-8 pt-14 pb-12">
    <h1 class="font-serif text-4xl md:text-5xl font-bold tracking-tight">Archive</h1>
    <p class="mt-3 text-[color:var(--muted)]">{all.length} article{all.length === 1 ? '' : 's'} in total.</p>
  </section>

  <section class="max-w-page mx-auto px-5 sm:px-8 pb-20">
    {years.map((y) => (
      <div class="mb-10">
        <h2 class="font-serif text-2xl font-semibold tracking-tight mb-3">{y}</h2>
        <ul class="divide-y divide-[color:var(--rule)] border-y border-[color:var(--rule)]">
          {byYear.get(y)!.map((a) => (
            <li class="py-3 flex items-baseline gap-4">
              <time class="text-xs text-[color:var(--muted)] w-20 shrink-0" datetime={a.data.date.toISOString()}>
                {a.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
              </time>
              <a href={`/articles/${a.slug}`} class="flex-1 hover:text-[color:var(--accent)]">
                <span class="font-medium">{a.data.title}</span>
              </a>
              <span class="hidden sm:inline text-xs text-[color:var(--muted)] uppercase tracking-wide">
                {CATEGORIES[a.data.category].label}
              </span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>
