---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBox from '../components/SearchBox.astro';
---

<BaseLayout title="Search" description="Search every Signal article." pathname="/search">
  <section class="max-w-page mx-auto px-5 sm:px-8 pt-14 pb-20">
    <h1 class="font-serif text-4xl md:text-5xl font-bold tracking-tight">Search</h1>
    <p class="mt-3 text-[color:var(--muted)]">Type to find any article. Index updates at build time.</p>
    <div class="mt-8 max-w-2xl">
      <SearchBox />
    </div>
  </section>
</BaseLayout>
