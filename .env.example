# Public Buttondown handle for newsletter form (no secret). e.g. "signal"
PUBLIC_BUTTONDOWN_USERNAME=

# Optional: set when running scripts that may need network identity
USER_AGENT="SignalBot/0.1 (+https://signal.pages.dev)"

# Comma-separated list of Nitter instances the ingest script rotates through when
# fetching X profiles. First one that returns a valid feed wins. Override if the
# defaults are down (they come and go).
NITTER_INSTANCES="https://nitter.net,https://nitter.privacydev.net,https://nitter.poast.org,https://nitter.unixfox.eu"

# Skip the plagiarism HTTP fetch in scripts/verify-article.ts (still checks
# frontmatter and required sections). CI uses VERIFY_FETCH=0.
# VERIFY_FETCH=0
